# ─────────────────────────────────────────────────────────────────
# AniSage — Environment Configuration
# Copy this file to .env and fill in your secrets.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────

# Required ─────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
HUGGINGFACEHUB_API_TOKEN=your_huggingface_token_here

# LLM settings (optional — sensible defaults provided) ─────────────
MODEL_NAME=llama-3.1-8b-instant
LLM_TEMPERATURE=0

# Embedding model (optional) ────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Vector store (optional) ───────────────────────────────────────────
CHROMA_PERSIST_DIR=chroma_db
CHUNK_SIZE=1000
CHUNK_OVERLAP=100
RETRIEVER_K=5

# Data paths (optional) ─────────────────────────────────────────────
RAW_DATA_PATH=data/anime_with_synopsis.csv
PROCESSED_DATA_PATH=data/anime_processed.csv
